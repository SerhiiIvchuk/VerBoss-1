# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.env

# Важливо для нової структури: ігноруємо кеш всередині папки src
src/**/__pycache__/
src/**/*.pyc

# --- Віртуальні середовища ---
venv/
.venv/
ENV/
env.bak/
venv.bak/

# --- FastAPI / Налаштування ---
.env
.flaskenv
*.log
auth_token.txt

# --- Бази даних (SQLite) ---
# Ігноруємо всі файли баз, але НЕ ігноруємо файл .gitkeep
# Це дозволить папці data з'явитися у всіх учнів порожньою
data/*
!data/.gitkeep

# --- Docker ---
.docker/
*.dockerlog

# --- Редактори та ОС ---
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Захист від великих файлів ---
*.bak
*.zip
*.tar.gz
*.rar
*.7z
*.iso
*.sql

# --- Frontend (Node.js / Vue.js) ---
# Залежності
node_modules/
.pnpm-store/

# Результати збірки (Build artifacts)
dist/
dist-ssr/
*.mjs.map

# Логи пакетних менеджерів
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Локальні змінні оточення (Frontend)
.env.local
.env.*.local

# Тайпскрипт та кеш
.tsbuildinfo
.eslintcache