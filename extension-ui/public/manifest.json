{
    "manifest_version": 3,
    "name": "VerBoss",
    "version": "1.0.0",
    "key": "",
    "permissions": [
        "storage",
        "activeTab",
        "notifications",
        "identity"
    ],
    "host_permissions": [
        "https://*.ngrok-free.dev/*"
    ],
    "action": {
        "default_popup": "index.html",
        "default_icon": {
            "16": "images/icon16.png",
            "48": "images/icon48.png",
            "128": "images/icon128.png"
        }
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    }
}